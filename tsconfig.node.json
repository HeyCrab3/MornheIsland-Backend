{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "skipLibCheck": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["/*"],
    }
  }
}
